    {
      "name": "Casos de Erro (Regras de Negócio)",
      "description": "Testa as validações de negócio — todas devem retornar erro",
      "item": [
        {
          "name": "01 — ISBN Duplicado → 409 Conflict",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"titulo\": \"Outro Livro com ISBN Igual\",\n  \"isbn\": \"9780132350884\",\n  \"anoPublicacao\": 2020,\n  \"autorId\": \"{{autor_id_martin}}\",\n  \"generoId\": \"{{genero_id_tecnologia}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/livros",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "livros"
              ]
            }
          }
        },
        {
          "name": "02 — E-mail Duplicado → 409 Conflict",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Outro Autor\",\n  \"email\": \"uncle.bob@cleancode.com\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/autores",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "autores"
              ]
            }
          }
        },
        {
          "name": "03 — Deletar Autor com Livros → 422 Unprocessable Entity",
          "description": "Tenta deletar um autor que possui livros vinculados.",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{base_url}}/autores/{{autor_id_martin}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "autores",
                "{{autor_id_martin}}"
              ]
            }
          }
        },
        {
          "name": "04 — Deletar Gênero com Livros → 422 Unprocessable Entity",
          "description": "Tenta deletar um gênero que possui livros vinculados.",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{base_url}}/generos/{{genero_id_tecnologia}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "generos",
                "{{genero_id_tecnologia}}"
              ]
            }
          }
        },
        {
          "name": "05 — Recurso não encontrado → 404 Not Found",
          "description": "Busca um ID inexistente.",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/livros/00000000-0000-0000-0000-000000000000",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "livros",
                "00000000-0000-0000-0000-000000000000"
              ]
            }
          }
        },
        {
          "name": "06 — Campos obrigatórios em branco → 400 Bad Request",
          "description": "Envia body com campos obrigatórios ausentes.",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"titulo\": \"\",\n  \"isbn\": \"\",\n  \"anoPublicacao\": 0,\n  \"autorId\": \"\",\n  \"generoId\": \"\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/livros",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "livros"
              ]
            }
          }
        },
        {
          "name": "07 — Ano de Publicação inválido → 400 Bad Request",
          "description": "Envia um ano de publicação fora do intervalo válido (1400 - ano atual).",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
