        {
          "name": "01 — Criar Gênero: Tecnologia",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    var json = pm.response.json();",
                  "    pm.collectionVariables.set('genero_id_tecnologia', json.data.id);",
                  "    console.log('genero_id_tecnologia:', json.data.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Tecnologia\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/generos",
