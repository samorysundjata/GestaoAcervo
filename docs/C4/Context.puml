@startuml Context
' Diagrama de Contexto - Gestão Acervo - C4 Model
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Context.puml

LAYOUT_WITH_LEGEND()

title Gestão Acervo - Diagrama de Contexto

Person(user, "Usuário", "Gerencia o acervo de livros, autores e gêneros")

System(gestaoAcervo, "Gestão Acervo", "Sistema de gerenciamento de acervo com cadastro de autores, gêneros e livros")

System_Ext(sqlServer, "SQL Server", "Banco de dados relacional para persistência de dados")

Rel(user, gestaoAcervo, "Utiliza", "HTTP/HTTPS")
Rel(gestaoAcervo, sqlServer, "Lê/Escreve", "T-SQL")

SHOW_LEGEND()

@enduml